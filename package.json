{
  "name": "michelin-restaurants",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "http://michelin.thefrenchartist.dev/",
  "scripts": {
    "dev": "vite",
    "data": "python3 scripts/generate_restaurants_csv.py",
    "refresh": "test -s public/data/restaurants.csv || npm run data",
    "build": "npm run refresh && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy": "npm run build && gh-pages -d dist --cname michelin.thefrenchartist.dev"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "gh-pages": "^6.3.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.555.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "autoprefixer": "^10.4.22",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
